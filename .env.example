# Supabase (local dev - from `supabase start`)
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=

# Supabase (production)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Postgres direct connection (from `supabase start` output, or production DB URL)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Base URL for token links in emails (no trailing slash)
APP_URL=http://localhost:5173

# Server-side (Vercel functions only - not prefixed with VITE_)
SUPABASE_SERVICE_ROLE_KEY=

# Resend (email)
RESEND_API_KEY=

# Google Drive API
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_DRIVE_FOLDER_ID=

# JWT secret for admin auth
JWT_SECRET=
