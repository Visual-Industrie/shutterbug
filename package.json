{
  "name": "shutterbug",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently --names \"api,ui\" --prefix-colors \"yellow,cyan\" \"npm run dev:api\" \"npm run dev:ui\"",
    "dev:api": "tsx scripts/dev-api.ts",
    "dev:ui": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "types:gen": "supabase gen types typescript --local > src/types/supabase.ts",
    "seed:admin": "tsx scripts/seed-admin.ts",
    "import:click": "tsx scripts/import-click-data.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "@tailwindcss/vite": "^4.2.0",
    "@tanstack/react-query": "^5.90.21",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "@types/busboy": "^1.5.4",
    "@types/express": "^5.0.6",
    "bcryptjs": "^3.0.3",
    "busboy": "^1.6.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.40.1",
    "express": "^5.2.1",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.2.0",
    "resend": "^6.9.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.5",
    "@types/pg": "^8.16.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/sharp": "^0.31.1",
    "@vercel/node": "^5.6.6",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.30.4",
    "pg": "^8.18.0",
    "supabase": "^2.79.0",
    "tsx": "^4.21.0",
    "typescript": "~5.7.2",
    "vite": "^6.2.0",
    "xlsx": "^0.18.5"
  }
}
